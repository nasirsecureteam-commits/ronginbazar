<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ===== DATA STORE =====
let products = JSON.parse(localStorage.getItem('rb_products') || '[]');
let orders = JSON.parse(localStorage.getItem('rb_orders') || '[]');
let cart = [];
let uploadedImg = null;
let currentFilter = 'all';
const ADMIN_USER = 'admin';
const ADMIN_PASS = 'sweety2024';

// Sample products if empty
if(products.length === 0){
  products = [
    {id:1,name:'জামদানি শাড়ি',cat:'শাড়ি',price:1200,old:1500,stock:25,badge:'নতুন',img:null,desc:'হাতে বোনা জামদানি শাড়ি'},
    {id:2,name:'মসলিন শাড়ি',cat:'শাড়ি',price:980,old:1200,stock:5,badge:'হট',img:null,desc:'মসৃণ মসলিন কাপড়'},
    {id:3,name:'সুতি কাপড় (গজ)',cat:'কাপড়',price:120,old:150,stock:100,badge:'',img:null,desc:''},
    {id:4,name:'প্লাস্টিক গাড়ি সেট',cat:'খেলনা',price:250,old:320,stock:0,badge:'নতুন',img:null,desc:'শিশুদের জন্য রঙিন গাড়ি সেট'},
    {id:5,name:'পুতুল সেট',cat:'খেলনা',price:180,old:230,stock:30,badge:'',img:null,desc:''},
  ];
  saveProducts();
}

function saveProducts(){ localStorage.setItem('rb_products',JSON.stringify(products)); }
function saveOrders(){ localStorage.setItem('rb_orders',JSON.stringify(orders)); }

// ===== NAVIGATION =====
function showPage(id){ document.querySelectorAll('.page').forEach(p=>p.classList.remove('active')); document.getElementById(id).classList.add('active'); window.scrollTo(0,0); }
function goShop(){ showPage('shopPage'); renderShop(currentFilter); }
function goLogin(){ showPage('loginPage'); }
function goAdmin(){ showPage('adminPage'); renderAdmin(); }
function doLogout(){ goShop(); }

// ===== LOGIN =====
function doLogin(){
  const u=document.getElementById('loginUser').value.trim();
  const p=document.getElementById('loginPass').value;
  if(u===ADMIN_USER && p===ADMIN_PASS){ document.getElementById('loginErr').style.display='none'; goAdmin(); }
  else { document.getElementById('loginErr').style.display='block'; }
}

// ===== SHOP =====
const catEmoji = {শাড়ি:'🥻',কাপড়:'🧵',খেলনা:'🧸',অন্যান্য:'📦'};

function renderShop(filter='all'){
  const grid = document.getElementById('shopGrid');
  const q = document.getElementById('searchQ').value.toLowerCase().trim();
  let list = filter==='all' ? [...products] : products.filter(p=>p.cat===filter);
  if(q) list = list.filter(p=>p.name.toLowerCase().includes(q)||p.cat.toLowerCase().includes(q));
  document.getElementById('noProducts').style.display = list.length===0?'block':'none';
  grid.innerHTML = list.map(p=>{
    const outStock = p.stock===0;
    const lowStock = p.stock>0 && p.stock<=5;
    const imgHtml = p.img ? `<img src="${p.img}" style="width:100%;height:100%;object-fit:cover;">` : `<span class="no-img">${catEmoji[p.cat]||'📦'}</span>`;
    const badgeCls = p.badge==='নতুন'?'badge-new':p.badge==='হট'?'badge-hot':'badge-off';
    return `<div class="prod-card">
      <div class="prod-img-wrap">
        ${imgHtml}
        ${p.badge?`<div class="prod-badge ${badgeCls}">${p.badge}</div>`:''}
        ${outStock?`<div class="stock-low">স্টক নেই</div>`:''}
        ${lowStock?`<div class="stock-low">মাত্র ${p.stock}টি বাকি</div>`:''}
      </div>
      <div class="prod-info">
        <div class="prod-name">${p.name}</div>
        <div class="prod-price-row">
          <span class="p-new">৳ ${p.price.toLocaleString()}</span>
          ${p.old?`<span class="p-old">৳ ${p.old}</span>`:''}
        </div>
        <div class="prod-acts">
          <button class="btn-cart" onclick="addToCart(${p.id})" ${outStock?'disabled':''}>
            ${outStock?'স্টক নেই':'🛒 কার্টে যোগ করুন'}
          </button>
          <button class="btn-wish" onclick="this.classList.toggle('on');this.textContent=this.classList.contains('on')?'❤️':'🤍'">🤍</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function filterShop(cat, btn){
  currentFilter = cat;
  document.querySelectorAll('.cbt').forEach(b=>b.classList.remove('active'));
  if(btn) btn.classList.add('active');
  document.getElementById('shopTitle').textContent = cat==='all'?'সব পণ্য':cat;
  renderShop(cat);
}

function searchProducts(){ renderShop(currentFilter); }

// ===== CART =====
function addToCart(id){
  const p = products.find(x=>x.id===id);
  if(!p||p.stock===0) return;
  const ex = cart.find(x=>x.id===id);
  if(ex){ if(ex.qty>=p.stock){showToast('⚠️ স্টক সীমা পার হয়েছে!');return;} ex.qty++; }
  else cart.push({...p,qty:1});
  updateCartBadge(); renderCart();
  showToast(`✅ ${p.name} কার্টে যোগ হয়েছে!`);
}

function updateCartBadge(){ document.getElementById('cartBadge').textContent=cart.reduce((s,i)=>s+i.qty,0); }

function renderCart(){
  const body=document.getElementById('cartBody'), foot=document.getElementById('cartFoot');
  if(cart.length===0){
    body.innerHTML=`<div class="empty-box"><div class="big">🛒</div><p>কার্ট খালি</p></div>`;
    foot.style.display='none'; return;
  }
  foot.style.display='block';
  body.innerHTML=cart.map(i=>{
    const imgHtml=i.img?`<img src="${i.img}">`:`${catEmoji[i.cat]||'📦'}`;
    return `<div class="cart-item">
      <div class="ci-img">${imgHtml}</div>
      <div class="ci-info">
        <div class="ci-name">${i.name}</div>
        <div class="ci-price">৳ ${i.price}</div>
        <div class="ci-qty">
          <button class="qbtn" onclick="chQty(${i.id},-1)">−</button>
          <span class="qnum">${i.qty}</span>
          <button class="qbtn" onclick="chQty(${i.id},1)">+</button>
        </div>
      </div>
      <button class="ci-del" onclick="delCart(${i.id})">🗑️</button>
    </div>`;
  }).join('');
  const total=cart.reduce((s,i)=>s+(i.price*i.qty),0);
  document.getElementById('cartTotal').textContent='৳ '+total.toLocaleString();
}

function chQty(id,d){
  const item=cart.find(x=>x.id===id);
  const prod=products.find(x=>x.id===id);
  if(!item) return;
  item.qty+=d;
  if(item.qty<=0) cart=cart.filter(x=>x.id!==id);
  else if(prod && item.qty>prod.stock){ item.qty=prod.stock; showToast('⚠️ স্টক সীমা পার হয়েছে!'); }
  updateCartBadge(); renderCart();
}

function delCart(id){ cart=cart.filter(x=>x.id!==id); updateCartBadge(); renderCart(); }
function toggleCart(){ document.getElementById('cartOverlay').classList.toggle('open'); document.getElementById('cartPanel').classList.toggle('open'); }

// ===== ORDER =====
function openOrderForm(){
  if(cart.length===0) return;
  const total=cart.reduce((s,i)=>s+(i.price*i.qty),0);
  document.getElementById('orderSummary').innerHTML=`
    <h4>অর্ডার সারসংক্ষেপ</h4>
    ${cart.map(i=>`<div class="os-item"><span>${i.name} ×${i.qty}</span><span>৳ ${i.price*i.qty}</span></div>`).join('')}
    <div class="os-total"><span>মোট</span><span>৳ ${total.toLocaleString()}</span></div>`;
  document.getElementById('orderModal').classList.add('open');
}

function closeOrderModal(){ document.getElementById('orderModal').classList.remove('open'); }

function placeOrder(){
  const name=document.getElementById('oName').value.trim();
  const phone=document.getElementById('oPhone').value.trim();
  const address=document.getElementById('oAddress').value.trim();
  if(!name||!phone||!address){ showToast('⚠️ সব তারকা চিহ্নিত তথ্য পূরণ করুন!'); return; }
  const order={
    id: orders.length+1,
    name, phone, address,
    payment: document.getElementById('oPayment').value,
    note: document.getElementById('oNote').value,
    items: cart.map(i=>({name:i.name,qty:i.qty,price:i.price})),
    total: cart.reduce((s,i)=>s+(i.price*i.qty),0),
    status:'নতুন',
    date: new Date().toLocaleDateString('bn-BD')
  };
  // Reduce stock
  cart.forEach(ci=>{ const p=products.find(x=>x.id===ci.id); if(p) p.stock=Math.max(0,p.stock-ci.qty); });
  saveProducts();
  orders.unshift(order); saveOrders();
  cart=[]; updateCartBadge(); renderCart();
  closeOrderModal();
  document.getElementById('cartPanel').classList.remove('open');
  document.getElementById('cartOverlay').classList.remove('open');
  renderShop(currentFilter);
  showToast('🎉 অর্ডার সফলভাবে হয়েছে! আমরা শীঘ্রই যোগাযোগ করব।');
}

// ===== IMAGE UPLOAD =====
function handleImgUpload(e){
  const file=e.target.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=ev=>{
    uploadedImg=ev.target.result;
    const prev=document.getElementById('imgPreview');
    prev.src=uploadedImg; prev.style.display='block';
    document.querySelector('#imgUploadBox .up-icon').textContent='✅';
    document.querySelector('#imgUploadBox p').textContent='ছবি আপলোড হয়েছে';
  };
  reader.readAsDataURL(file);
}

// ===== ADD PRODUCT =====
function addProduct(){
  const name=document.getElementById('pName').value.trim();
  const price=parseInt(document.getElementById('pPrice').value);
  const stock=parseInt(document.getElementById('pStock').value);
  if(!name||!price||isNaN(stock)){ showToast('⚠️ নাম, মূল্য ও স্টক আবশ্যক!'); return; }
  const np={
    id: Date.now(),
    name,
    cat: document.getElementById('pCat').value,
    price,
    old: parseInt(document.getElementById('pOld').value)||0,
    stock,
    badge: document.getElementById('pBadge').value,
    img: uploadedImg||null,
    desc: document.getElementById('pDesc').value
  };
  products.unshift(np); saveProducts();
  // Reset form
  ['pName','pPrice','pOld','pStock','pDesc'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('pBadge').value='';
  document.getElementById('imgPreview').style.display='none';
  document.querySelector('#imgUploadBox .up-icon').textContent='📷';
  document.querySelector('#imgUploadBox p').textContent='ছবি আপলোড করতে ক্লিক করুন';
  uploadedImg=null;
  renderAdmin(); switchTab('products',document.querySelector('.atab'));
  showToast(`✅ "${name}" পণ্য যোগ হয়েছে!`);
}

// ===== DELETE PRODUCT =====
function deleteProduct(id){
  if(!confirm('এই পণ্য মুছে দিতে চান?')) return;
  products=products.filter(p=>p.id!==id); saveProducts(); renderAdmin();
  showToast('🗑️ পণ্য মুছে গেছে');
}

// ===== UPDATE STOCK =====
function updateStock(id){
  const val=parseInt(document.getElementById('stock_'+id).value);
  if(isNaN(val)||val<0){ showToast('⚠️ সঠিক স্টক দিন!'); return; }
  const p=products.find(x=>x.id===id); if(!p) return;
  p.stock=val; saveProducts(); renderAdmin();
  showToast('✅ স্টক আপডেট হয়েছে!');
}

// ===== ADMIN RENDER =====
function renderAdmin(){
  // Stats
  const totalProd=products.length;
  const totalOrders=orders.length;
  const totalRevenue=orders.reduce((s,o)=>s+o.total,0);
  const lowStock=products.filter(p=>p.stock<=5).length;
  document.getElementById('statsGrid').innerHTML=`
    <div class="stat-card"><div class="stat-num">${totalProd}</div><div class="stat-label">মোট পণ্য</div></div>
    <div class="stat-card green"><div class="stat-num">${totalOrders}</div><div class="stat-label">মোট অর্ডার</div></div>
    <div class="stat-card blue"><div class="stat-num">৳${totalRevenue.toLocaleString()}</div><div class="stat-label">মোট আয়</div></div>
    <div class="stat-card orange"><div class="stat-num">${lowStock}</div><div class="stat-label">কম স্টক পণ্য</div></div>`;

  // Product List
  document.getElementById('adminProdList').innerHTML = products.map(p=>{
    const sClass=p.stock===0?'s-out':p.stock<=5?'s-low':'s-ok';
    const sText=p.stock===0?'স্টক নেই':p.stock<=5?'কম স্টক':'পর্যাপ্ত';
    const imgHtml=p.img?`<img src="${p.img}">`:`${catEmoji[p.cat]||'📦'}`;
    return `<div class="admin-prod-item">
      <div class="api-img">${imgHtml}</div>
      <div class="api-info">
        <div class="api-name">${p.name}</div>
        <div class="api-meta">${p.cat} · <span class="stock-badge ${sClass}">${sText} (${p.stock})</span></div>
        <div class="stock-edit">
          <span style="font-size:11px;color:var(--muted)">স্টক:</span>
          <input id="stock_${p.id}" type="number" value="${p.stock}" min="0">
          <button onclick="updateStock(${p.id})">আপডেট</button>
        </div>
      </div>
      <div class="api-price">৳ ${p.price.toLocaleString()}</div>
      <div class="api-acts">
        <button class="icon-btn del" onclick="deleteProduct(${p.id})" title="মুছুন">🗑️</button>
      </div>
    </div>`;
  }).join('') || '<div style="text-align:center;padding:30px;color:var(--muted);">কোনো পণ্য নেই। নতুন পণ্য যোগ করুন।</div>';

  // Orders
  const tbody=document.getElementById('ordersBody');
  document.getElementById('noOrders').style.display=orders.length===0?'block':'none';
  tbody.innerHTML=orders.map(o=>`
    <tr>
      <td>#${o.id}</td>
      <td>${o.name}<br><small style="color:var(--muted)">${o.address.substring(0,20)}...</small></td>
      <td>${o.phone}</td>
      <td>${o.items.map(i=>`${i.name}×${i.qty}`).join(', ')}</td>
      <td style="font-weight:700;color:var(--rose)">৳${o.total.toLocaleString()}</td>
      <td>${o.payment}</td>
      <td>
        <select class="status-select" onchange="updateOrderStatus(${o.id},this.value)">
          <option ${o.status==='নতুন'?'selected':''}>নতুন</option>
          <option ${o.status==='প্রসেসিং'?'selected':''}>প্রসেসিং</option>
          <option ${o.status==='সম্পন্ন'?'selected':''}>সম্পন্ন</option>
        </select>
      </td>
    </tr>`).join('');
}

function updateOrderStatus(id,status){
  const o=orders.find(x=>x.id===id); if(!o) return;
  o.status=status; saveOrders(); showToast('✅ স্ট্যাটাস আপডেট হয়েছে');
}

function switchTab(name, btn){
  document.querySelectorAll('.admin-tab-content').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.atab').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  if(btn) btn.classList.add('active');
}

// ===== TOAST =====
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}

// Init
renderShop('all');
</script>
</body>
</html>
